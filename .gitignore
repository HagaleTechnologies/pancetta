# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


.claude

# Release artifacts
/release/
*.tar.gz
*.zip

# Logs
*.log
logs/

# Test outputs
*.out
test-results/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Docker volumes
pancetta-data/
pancetta-cache/

# Configuration backups
*.toml.backup
config.toml.bak

# Environment files with secrets
.env
.env.local
.env.production

# Credentials, private keys & certificates — NEVER commit these.
# Includes TQSL/LoTW station certs (.p12/.tq5/.tq6) and TLS keys.
*.p12
*.pfx
*.pem
*.key
*.tq5
*.tq6
id_rsa
id_ed25519

# Operator runtime state (lives in ~/.pancetta, but ignore defensively in case
# a contributor points HOME at the repo or copies it in). These hold the
# operator's callsign/credentials and logged-QSO PII.
.pancetta/
pancetta.toml
# ADIF logs + the SQLite QSO index + WAV captures (callsigns/grids/timestamps).
*.adi
*.adif
qso.db
qso.db-*
recordings/
tier_cache.json

# Benchmark results
benchmarks/results/

# Git worktrees
.worktrees/

# Python virtual environments
.venv/
__pycache__/
*.pyc

# Training artifacts (regenerate with training/neural_osd/README.md)
training/neural_osd/data/
training/neural_osd/data_test/
training/neural_osd/model.pt
training/neural_osd/session2_best.pt
training/neural_osd/session2_best.metrics.json
training/neural_osd/session2_train.log
# hb-194 ensemble training artifacts
training/neural_osd/ensemble_seed_*.pt
training/neural_osd/ensemble_seed_*.metrics.json
training/neural_osd/ensemble_nb_seed_*.pt
training/neural_osd/ensemble_nb_seed_*.metrics.json
training/neural_osd/ensemble_train_summary.json
training/neural_osd/train_ensemble.log
training/neural_osd/ensemble_eval.json
training/neural_osd/ensemble_nb_eval.json
training/neural_osd/train_ensemble.stdout.log
training/neural_osd/train_ensemble_nb.stdout.log
training/neural_osd/ensemble_inference.stdout.log
training/neural_osd/ensemble_nb_inference.stdout.log
# hb-194 Session 2 — N=8 ensemble checkpoints used to produce the
# weight-space averaged (Wortsman 2022 model-soup) blob. The averaged
# blob is reproducible from these via average_ensemble_weights.py.
training/neural_osd/session2/
# hb-064 Session 3 — Wortsman-compliant shared-init ensemble
# checkpoints. Same reproducibility story as Session 2.
training/neural_osd/session3/
*.npy

# Database backups
backups/

# Decoder research harness — local-only artifacts
# Spec: docs/superpowers/specs/2026-05-18-decoder-research-harness-design.md

# Synth corpus WAVs are generated; manifests + generator are committed
research/corpus/synth/wavs/

# ft8_lib truth/baseline JSONs — regenerated locally per corpus run, one file
# per WAV (tens of thousands). Local-only; never tracked. They also embedded the
# operator's home path, so they must stay out of the public repo. The .gitkeep
# placeholder is kept so the directory exists.
research/baselines/ft8/
!research/baselines/ft8/.gitkeep
research/baselines/

# Generated training data (large .npy etc.)
# Ignore contents, not the directory itself, so .gitkeep can stay tracked
# (git won't descend into an ignored dir to apply negation rules)
training/*/data/*
training/*/data_test/*
!training/*/data/.gitkeep
!training/*/data_test/.gitkeep

# Local research artifacts staging (if a script ever materializes weights
# inside the repo by mistake, ignore them)
research/corpus/curated/ft8/staged/

# hb-064 trajectory datasets — generated locally, regenerated per
# Session-2 retrain; sizes in the hundreds of MB. summary.json /
# README.txt / *.md inside the same experiment dir DO get tracked.
research/experiments/**/trajectories.jsonl
research/experiments/**/trajectories_recovered.jsonl
research/experiments/**/trajectories.npz
research/experiments/**/trajectories.parquet

# jt9 (WSJT-X CLI) side-effect files dropped into the working dir when
# the baseline binary runs from the workspace root
/decoded.txt
/jt9_wisdom.dat
