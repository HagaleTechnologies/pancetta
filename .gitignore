training/neural_osd/data/
training/neural_osd/data_test/
training/neural_osd/model.pt
training/neural_osd/session2_best.pt
training/neural_osd/session2_best.metrics.json
training/neural_osd/session2_train.log
# hb-194 ensemble training artifacts
training/neural_osd/ensemble_seed_*.pt
training/neural_osd/ensemble_seed_*.metrics.json
training/neural_osd/ensemble_nb_seed_*.pt
training/neural_osd/ensemble_nb_seed_*.metrics.json
training/neural_osd/ensemble_train_summary.json
training/neural_osd/train_ensemble.log
training/neural_osd/ensemble_eval.json
training/neural_osd/ensemble_nb_eval.json
training/neural_osd/train_ensemble.stdout.log
training/neural_osd/train_ensemble_nb.stdout.log
training/neural_osd/ensemble_inference.stdout.log
training/neural_osd/ensemble_nb_inference.stdout.log
*.npy

# Database backups
backups/

# Decoder research harness — local-only artifacts
# Spec: docs/superpowers/specs/2026-05-18-decoder-research-harness-design.md

# Synth corpus WAVs are generated; manifests + generator are committed
research/corpus/synth/wavs/

# Generated training data (large .npy etc.)
# Ignore contents, not the directory itself, so .gitkeep can stay tracked
# (git won't descend into an ignored dir to apply negation rules)
training/*/data/*
training/*/data_test/*
!training/*/data/.gitkeep
!training/*/data_test/.gitkeep

# Local research artifacts staging (if a script ever materializes weights
# inside the repo by mistake, ignore them)
research/corpus/curated/ft8/staged/

# hb-064 trajectory datasets — generated locally, regenerated per
# Session-2 retrain; sizes in the hundreds of MB. summary.json /
# README.txt / *.md inside the same experiment dir DO get tracked.
research/experiments/**/trajectories.jsonl
research/experiments/**/trajectories.npz
research/experiments/**/trajectories.parquet

# jt9 (WSJT-X CLI) side-effect files dropped into the working dir when
# the baseline binary runs from the workspace root
/decoded.txt
/jt9_wisdom.dat
