# Pancetta Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# Grafana admin password (change this!)
GRAFANA_ADMIN_PASSWORD=changeme

# Hamlib/rigctld configuration
RIGCTLD_HOST=127.0.0.1
RIGCTLD_PORT=4532

# Performance tuning
PANCETTA_WORKER_THREADS=2

# Audio configuration
PANCETTA_AUDIO_DEVICE=default
PANCETTA_STUB_AUDIO=false

# Use mock rig for testing
PANCETTA_MOCK_RIG=true

# Logging level (debug, info, warn, error)
RUST_LOG=info